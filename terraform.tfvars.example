#===============================================================================
# Cortex XDR Organization Connector - Terraform Variables Example
#===============================================================================

#---------------------------------------
# Palo Alto Networks Infrastructure (Required)
#---------------------------------------
# These values are extracted from the CloudFormation template Parameters
# section. They identify the Cortex outpost infrastructure and are typically
# the same across deployments in the same Cortex tenant.

# Assume-role principal ARN used by Cortex to access your account.
# CF parameter: OutpostRoleArn
outpost_role_arn = "arn:aws:iam::570214690022:role/gcp_saas_role"

# AWS account ID of the Cortex outpost.
# CF parameter: OutpostAccountId
outpost_account_id = "570214690022"

# AWS account ID that owns the KMS keys for ADS scanning.
# CF parameter: KmsAccountADS
kms_account_ads = "047719626164"

# AWS account ID that owns the KMS keys for DSPM scanning.
# CF parameter: MTKmsAccountDSPM
kms_account_dspm = "047719626164"

# Google service account ID used by the AWS CloudTrail collector.
# CF parameter: CollectorServiceAccountId
collector_service_account = "100995106428416677502"

# Audience value for the federated (Google) principal on the CloudTrail reader role.
# CF parameter: Audience
audience = "cortex-audit-logs"

# Suffix pattern for ADS copy-snapshot resource ARNs.
# CF parameter: CopySnapshotSuffix
copy_snapshot_suffix = "$${*}"

#---------------------------------------
# Template Versions (Required)
#---------------------------------------
# Version strings for each Cortex module template. These are sent during
# connector registration and must match the versions in your CF template's
# TemplateVersion block (under the Lambda custom resource properties).
template_versions = {
  discovery       = "1.0.5"
  base            = "1.4.0"
  audit_logs      = "1.1.0"
  ads             = "1.1.5"
  dspm            = "1.2.0"
  outpost_scanner = "1.2.0"
  registry        = "1.0.1"
  serverless      = "1.1.0"
  automation      = "1.0.3"
}

#---------------------------------------
# Core Cortex Parameters (Required)
#---------------------------------------

# Optional: Organizational Unit ID to deploy the StackSet to.
# Auto-detected from AWS Organizations when omitted (defaults to the org root).
# Override to target a specific OU instead of the entire organization.
# organizational_unit_id = "r-abc1234"

# Required: Unique External ID from Cortex XDR for the IAM trust relationship.
external_id = "1098fe55-ada3-48ce-98b4-fd135ce3b236"

# Required: Template ID from Cortex XDR (32-character hex string).
template_id = "420ba9fab49a455c95469e8d8658e568"

# Required: Signed URL for registration. This URL is generated by Cortex XDR
# and has an expiration date. Check your Cortex console if it has expired.
upload_output_url = "https://xdr-us-..."

#---------------------------------------
# Module Toggles (Optional)
#---------------------------------------
# Enable or disable individual Cortex modules. Each corresponds to a
# CloudFormation template variant from the Cortex console. By default
# all modules are disabled (BASE + DISCOVERY are always deployed).
#
# enable_modules = {
#   audit_logs = true   # Audit Logs / CloudTrail ingestion (default: true)
#   ads        = true   # Agentless Disk Scanning
#   dspm       = true   # Data Security Posture Management
#   registry   = true   # Container Registry Scanning
#   serverless = true   # Serverless Function Scanning
#   automation = true   # Automation / Remediation
# }

#---------------------------------------
# CloudTrail Integration (Optional)
#---------------------------------------
# Enable CloudTrail log ingestion by providing BOTH the S3 bucket name
# and the SNS topic ARN. If either is left empty, CloudTrail integration
# is disabled and no SQS queue, SNS subscription, or CloudTrail reader
# role will be created.
#
# These should point to the organization-wide CloudTrail trail configured
# in the management account.

# cloudtrail_logs_bucket = "my-org-cloudtrail-bucket"
# cloudtrail_sns_arn     = "arn:aws:sns:us-east-1:123456789012:org-trail-topic"

# Optional: If your CloudTrail logs are encrypted with a KMS key, provide
# the key ARN so the CloudTrail reader role gets kms:Decrypt permission.
# cloudtrail_kms_arn = "arn:aws:kms:us-east-1:123456789012:key/..."

#---------------------------------------
# Resource Naming (Optional)
#---------------------------------------
# By default, resources use the original Cortex naming convention with the
# suffix extracted from the CloudFormation template (e.g., "m-o-1006371815406").
# You can customize names in two ways:

# Option 1: Change the suffix for ALL resources at once.
# This affects roles, policies, SQS queues, Lambda, StackSet, and Security Groups.
# resource_suffix = "my-org-suffix"

# Option 2: Override specific resource names individually.
# Only include the names you want to change — unset fields keep the default.
# resource_names = {
#   platform_role   = "MyOrgPlatformRole"
#   scanner_role    = "MyOrgScannerRole"
#   sqs_queue       = "my-org-cloudtrail-queue"
#   stack_set       = "MyOrgCortexStackSet"
#   # ... only include what you want to override
# }

#---------------------------------------
# Account Filtering (Optional)
#---------------------------------------
# By default the StackSet deploys to ALL accounts in the target OU.
# Use ONE of the lists below to restrict which member accounts receive
# the deployment. Do NOT set both at the same time.

# Deploy ONLY to these accounts:
# include_account_ids = ["111111111111", "222222222222", "333333333333"]

# Deploy to all accounts EXCEPT these:
# exclude_account_ids = ["999999999999", "888888888888"]

#---------------------------------------
# VPC Deployment (Optional)
#---------------------------------------
# By default, the registration Lambda runs in the standard AWS-managed
# environment with direct internet access (deploy_in_vpc = false).
#
# Enable this to deploy the Lambda inside your management account VPC
# instead. This is required in environments where Lambda functions must
# run within a private network (e.g., enterprise security policies,
# compliance, strict egress controls).
#
# PREREQUISITES:
#   - The VPC must have a NAT Gateway in at least one of the private
#     subnets listed below. The Lambda must reach googleapis.com over
#     HTTPS to complete registration.
#   - The subnets must be PRIVATE (routed through a NAT Gateway).
#     Public subnets will NOT work. Lambda ENIs never receive a public
#     IP (even if the subnet has auto-assign public IP enabled — that
#     only applies to EC2). Without a public IP, an Internet Gateway
#     cannot route traffic out, and outbound requests will time out.
#     The working path is:
#       Lambda ENI (private subnet) -> NAT GW (public subnet) -> IGW -> internet
#   - At least one of vpc_id or vpc_security_group_ids must be set
#     so the Lambda has a Security Group to attach to.

# deploy_in_vpc = true

# Required when deploy_in_vpc = true. List of private subnet IDs where
# the Lambda will create Elastic Network Interfaces (ENIs). Use at least
# two subnets in different AZs for high availability.
# vpc_subnet_ids = ["subnet-0abc123", "subnet-0def456"]

# Option A: Provide your VPC ID and the module creates a managed Security
# Group that allows HTTPS (port 443) egress to 0.0.0.0/0. No ingress
# rules are added — the Lambda only makes outbound calls.
# vpc_id = "vpc-0abc123456"

# Option B: Bring your own Security Group(s) with the egress rules your
# organization requires. The SG must allow outbound HTTPS (port 443) to
# reach googleapis.com for registration.
# vpc_security_group_ids = ["sg-0abc123456"]

# You can combine both options — the module will merge the managed SG
# with your custom SGs into a single list on the Lambda.

#---------------------------------------
# Tags (Optional)
#---------------------------------------
# Additional tags applied to all resources created by this module.
# The tag "managed_by = paloaltonetworks" is always added automatically.
# additional_tags = {
#   Environment = "production"
#   Team        = "security"
# }

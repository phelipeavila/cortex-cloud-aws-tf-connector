# Local .terraform directories
**/.terraform/*

# Terraform lock file (keep if you want reproducible provider versions)
# .terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan
*.tfplan.*
tfplan

# Crash log files
crash.log
crash.*.log

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
*.tfvars.bak
!terraform.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc

# Generated files
*.auto.tfvars
lambda_function.zip

# SSH keys
*.pem
*.key

# Generated connector files
*connectors_aws_cf-*.yml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
*.egg
cortex-aws-connector.code-workspace
lambda_function.zip
.DS_Store
